# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# Backtrace / debug output
rust-toolchain-*.tar.gz

# Local editor / agent tooling (not part of the project) — but keep the
# command files (`/.claude/commands/`) version-controlled so edits to them go
# through review.
/.claude/*
!/.claude/commands/

# VS Code extension build artifacts
editors/vscode/*.vsix
editors/vscode/node_modules/
